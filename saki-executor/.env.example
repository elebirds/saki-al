# 留空时默认使用主机名作为 executor_id
EXECUTOR_ID=
EXECUTOR_VERSION=0.1.0
API_GRPC_TARGET=localhost:50051
INTERNAL_TOKEN=dev-secret
HEARTBEAT_INTERVAL_SEC=10

RUNS_DIR=runs
CACHE_DIR=cache
CACHE_MAX_BYTES=536870912000

DEFAULT_GPU_IDS=0
CPU_WORKERS=4
MEMORY_MB=0

LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_NAME=executor.log
LOG_MAX_BYTES=20971520
LOG_BACKUP_COUNT=5

ENABLE_COMMAND_STDIN=true
DISCONNECT_FORCE_WAIT_SEC=20
