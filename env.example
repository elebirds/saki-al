# Saki 部署环境变量配置示例
# 复制此文件为 .env 并修改相应的值

# 数据库配置
# 统一使用 PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/saki

# 内置 PostgreSQL 容器初始化参数（仅 docker-compose 内置 postgres 使用）
# 为避免与系统环境中的 POSTGRES_* 冲突，统一使用 SAKI_POSTGRES_* 前缀
SAKI_POSTGRES_DB=saki
SAKI_POSTGRES_USER=postgres
SAKI_POSTGRES_PASSWORD=postgres

# 快速开发模式：后端启动时会自动执行 SQLModel.create_all
# 需要重建结构时，直接删库/删表后重启服务

# 安全配置
# 请务必在生产环境中更改此密钥！
# 可以使用以下命令生成: openssl rand -hex 32
SECRET_KEY=YOUR_SUPER_SECRET_KEY_CHANGE_ME_IN_PRODUCTION

# CORS 配置
# 允许的前端域名列表（JSON 格式）
# 生产环境请设置为实际的域名
BACKEND_CORS_ORIGINS=["http://localhost","http://localhost:80","http://localhost:3000","http://localhost:5173"]

# Token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=30

# MinIO 对象存储配置
# 是否启用内置 MinIO 服务（docker-compose profile=minio）
# true: 启用内置 MinIO；false: 不启动 MinIO，直接使用外部 OSS/S3 兼容存储
ENABLE_MINIO=true

# MinIO 服务器地址（不包含 http:// 或 https://）
# 使用外部 OSS/S3 兼容存储时，请改成对应 endpoint（例如 oss-cn-hangzhou.aliyuncs.com）
MINIO_ENDPOINT=localhost:9000

# MinIO 访问密钥
MINIO_ACCESS_KEY=minioadmin

# MinIO 私密密钥
MINIO_SECRET_KEY=minioadmin

# 是否使用 HTTPS 连接 MinIO（生产环境建议设为 true）
MINIO_SECURE=false

# MinIO 存储桶名称
MINIO_BUCKET_NAME=saki-data

# Redis (Working Area Cache)
# 例如：redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=saki
REDIS_WORKING_TTL_SECONDS=86400

# Runtime control plane
INTERNAL_TOKEN=dev-secret
RUNTIME_DOMAIN_GRPC_BIND=0.0.0.0:50053
RUNTIME_UPLOAD_URL_EXPIRE_HOURS=2
RUNTIME_MAX_RETRY_COUNT=2
RUNTIME_DOMAIN_GRPC_SERVER_ENABLED=true

# Dispatcher admin bridge (api -> dispatcher)
DISPATCHER_ADMIN_TARGET=localhost:50052
DISPATCHER_ADMIN_TIMEOUT_SEC=5

# Dispatcher runtime-domain bridge (dispatcher -> api)
RUNTIME_DOMAIN_TARGET=localhost:50053
RUNTIME_DOMAIN_TOKEN=dev-secret

# Agent runtime-control stream (agent -> dispatcher)
RUNTIME_CONTROL_TARGET=localhost:50051
SAKI_AGENT_EXECUTOR_ID=
SAKI_AGENT_NODE_ID=
SAKI_AGENT_RUNTIME_KIND=saki-agent
SAKI_AGENT_VERSION=dev
SAKI_AGENT_HEARTBEAT_INTERVAL_SEC=10
SAKI_AGENT_CONNECT_TIMEOUT_SEC=5
SAKI_AGENT_RECONNECT_INITIAL_BACKOFF_SEC=2
SAKI_AGENT_RECONNECT_MAX_BACKOFF_SEC=30
SAKI_AGENT_PLUGIN_IDS=saki-agent-placeholder
# 建议放在启动目录下，便于本地调试和清理
SAKI_AGENT_RUN_DIR=./.saki-agent/run
SAKI_AGENT_CACHE_DIR=./.saki-agent/cache
SAKI_AGENT_MINIO_ENDPOINT=
SAKI_AGENT_MINIO_ACCESS_KEY=
SAKI_AGENT_MINIO_SECRET_KEY=
SAKI_AGENT_MINIO_BUCKET=
SAKI_AGENT_MINIO_PREFIX=runtime-artifacts
SAKI_AGENT_MINIO_USE_SSL=false

# API 日志配置
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_NAME=api.log
LOG_MAX_BYTES=20971520
LOG_BACKUP_COUNT=5
# auto|on|off
LOG_COLOR_MODE=auto

# 前端 API 地址配置（构建时使用）
# 如果使用 nginx 代理，设置为相对路径: /api/v1
# 如果直接访问 API，设置为完整 URL: http://your-api-domain:8000/api/v1
VITE_API_BASE_URL=/api/v1

# 强制使用 HTTPS（前端）
# 设置为 'true' 时，前端会在相关操作（登录、注册、密码修改等）时强制要求 HTTPS
# 如果当前不是 HTTPS 协议，会抛出错误
# 默认不强制（不设置或设置为其他值）
VITE_FORCE_HTTPS=false

# FEDO 处理配置（统一使用 fedo. 前缀）
# 图像尺寸（英寸，JSON 数组）
fedo.figsize=[6.0,4.0]
# 生成图像的 DPI
fedo.dpi=200
# 允许的最大文件大小（MB）
fedo.max_file_size_mb=50
# 颜色映射
fedo.cmap=jet
# 轴范围（可选，JSON 数组）
# fedo.l_xlim=[1.2,1.9]
# fedo.wd_ylim=[0.0,4.0]
