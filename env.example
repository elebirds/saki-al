# Saki 部署环境变量配置示例
# 复制此文件为 .env 并修改相应的值

# 数据库配置
# SQLite (默认，数据库文件存储在 data 目录下)
DATABASE_URL=sqlite:///./data/saki.db

# PostgreSQL (生产环境推荐)
# DATABASE_URL=postgresql://user:password@postgres:5432/saki_db

# 安全配置
# 请务必在生产环境中更改此密钥！
# 可以使用以下命令生成: openssl rand -hex 32
SECRET_KEY=YOUR_SUPER_SECRET_KEY_CHANGE_ME_IN_PRODUCTION

# CORS 配置
# 允许的前端域名列表（JSON 格式）
# 生产环境请设置为实际的域名
BACKEND_CORS_ORIGINS=["http://localhost","http://localhost:80","http://localhost:3000","http://localhost:5173"]

# Token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=30

# MinIO 对象存储配置
# MinIO 服务器地址（不包含 http:// 或 https://）
MINIO_ENDPOINT=localhost:9000

# MinIO 访问密钥
MINIO_ACCESS_KEY=minioadmin

# MinIO 私密密钥
MINIO_SECRET_KEY=minioadmin

# 是否使用 HTTPS 连接 MinIO（生产环境建议设为 true）
MINIO_SECURE=false

# MinIO 存储桶名称
MINIO_BUCKET_NAME=saki-data

# 前端 API 地址配置（构建时使用）
# 如果使用 nginx 代理，设置为相对路径: /api/v1
# 如果直接访问 API，设置为完整 URL: http://your-api-domain:8000/api/v1
VITE_API_BASE_URL=/api/v1

# 强制使用 HTTPS（前端）
# 设置为 'true' 时，前端会在相关操作（登录、注册、密码修改等）时强制要求 HTTPS
# 如果当前不是 HTTPS 协议，会抛出错误
# 默认不强制（不设置或设置为其他值）
VITE_FORCE_HTTPS=false

# FEDO 处理配置（统一使用 fedo. 前缀）
# 图像尺寸（英寸，JSON 数组）
fedo.figsize=[6.0,4.0]
# 生成图像的 DPI
fedo.dpi=200
# 允许的最大文件大小（MB）
fedo.max_file_size_mb=50
# 颜色映射
fedo.cmap=jet
# 轴范围（可选，JSON 数组）
# fedo.l_xlim=[1.2,1.9]
# fedo.wd_ylim=[0.0,4.0]

