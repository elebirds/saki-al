# Saki 部署环境变量配置示例
# 复制此文件为 .env 并修改相应的值

# 数据库配置
# SQLite (默认)
DATABASE_URL=sqlite:///./saki.db

# PostgreSQL (生产环境推荐)
# DATABASE_URL=postgresql://user:password@postgres:5432/saki_db

# 安全配置
# 请务必在生产环境中更改此密钥！
# 可以使用以下命令生成: openssl rand -hex 32
SECRET_KEY=YOUR_SUPER_SECRET_KEY_CHANGE_ME_IN_PRODUCTION

# CORS 配置
# 允许的前端域名列表（JSON 格式）
# 生产环境请设置为实际的域名
BACKEND_CORS_ORIGINS=["http://localhost","http://localhost:3000","http://localhost:5173"]

# Token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 前端 API 地址配置（构建时使用）
# 如果使用 nginx 代理，设置为相对路径: /api/v1
# 如果直接访问 API，设置为完整 URL: http://your-api-domain:8000/api/v1
VITE_API_BASE_URL=/api/v1

